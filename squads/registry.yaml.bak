# ZVISION UNIFIED SQUAD REGISTRY
# Versão: 1.0.0
# Atualizado: 2026-04
# Total de squads únicos: 22
# Total de agentes: 300+

metadata:
  version: "1.0.0"
  description: "Registry unificado de todos os squads do Zvision-OS"
  sources:
    - sinapse-ai
    - brain-scott
    - xquads
    - gstack
    - highermind

squads:

  # ── DESENVOLVIMENTO ───────────────────────────────────────────
  - id: squad-dev
    name: "Development Squad"
    source: sinapse-ai
    agents: 12
    orquestrador: "@developer"
    description: "Implementação, arquitetura, QA, DevOps"
    skills:
      - "Story Development Cycle"
      - "Brownfield Discovery"
      - "Spec Pipeline"
    tools:
      - "/pwf-brainstorm"
      - "/pwf-plan"
      - "/pwf-work-plan"
      - "/pwf-review"
      - "/pwf-commit-changes"
    quando_usar:
      - "implementar qualquer feature"
      - "refatoração de código"
      - "debug e investigação"
      - "migrations de banco"

  # ── SEGURANÇA ─────────────────────────────────────────────────
  - id: squad-cybersecurity
    name: "Cybersecurity Squad"
    source: sinapse-ai
    agents: 15
    orquestrador: "@cyber-orqx"
    invoke: "/cyber:agents:cyber-orqx"
    description: "Segurança ofensiva e defensiva, pentest, compliance"
    tools:
      - "/cso"
    keywords: ["segurança", "audit", "pentest", "vulnerability", "OWASP", "RLS"]
    quando_usar:
      - "auditoria de segurança"
      - "antes de qualquer deploy em produção"
      - "review de código com acesso a dados sensíveis"
      - "configuração de RLS no Supabase"

  # ── COPY E COPYWRITING ────────────────────────────────────────
  - id: squad-copy
    name: "Copy Squad"
    source: sinapse-ai
    agents: 14
    orquestrador: "@copy-orqx"
    invoke: "/copywriting:agents:copy-orqx"
    description: "Copywriting persuasivo, headlines, conversão"
    keywords: ["copy", "texto", "headline", "landing", "email", "CTA", "persuasão"]
    quando_usar:
      - "escrever ou revisar qualquer copy"
      - "otimizar CTAs"
      - "criar sequências de email"
      - "revisar tom de voz"

  # ── DESIGN ────────────────────────────────────────────────────
  - id: squad-design
    name: "Design Squad"
    source: sinapse-ai
    agents: 8
    orquestrador: "@design-orqx"
    invoke: "/digital-experience:agents:design-orqx"
    description: "UI/UX, design systems, componentes, tokens"
    tools:
      - "/design-review"
      - "/design-shotgun"
      - "/design-html"
      - "/design-consultation"
    keywords: ["design", "interface", "ux", "ui", "componente", "layout", "visual"]
    quando_usar:
      - "auditar ou criar interfaces"
      - "criar design system"
      - "revisar qualidade visual"
      - "gerar variantes de design"

  # ── BRAND ─────────────────────────────────────────────────────
  - id: squad-brand
    name: "Brand Squad"
    source: sinapse-ai
    agents: 15
    orquestrador: "@brand-orqx"
    invoke: "/brand:agents:brand-orqx"
    description: "Estratégia de marca, arquetipos, posicionamento"
    keywords: ["marca", "branding", "posicionamento", "identidade", "arquetipos"]
    quando_usar:
      - "definir ou revisar posicionamento"
      - "criar identidade de marca para cliente"
      - "auditoria de marca"

  # ── TRÁFEGO E ADS ─────────────────────────────────────────────
  - id: squad-paidmedia
    name: "Paid Media Squad"
    source: sinapse-ai
    agents: 11
    orquestrador: "@paidmedia-orqx"
    invoke: "/pm:agents:paidmedia-orqx"
    description: "Tráfego pago, Meta Ads, Google Ads, otimização"
    keywords: ["tráfego", "ads", "campanha", "meta", "google", "mídia paga", "ROI"]
    quando_usar:
      - "criar ou revisar campanhas"
      - "analisar performance de ads"
      - "estratégia de mídia paga para clientes"

  # ── GROWTH ────────────────────────────────────────────────────
  - id: squad-growth
    name: "Growth Squad"
    source: sinapse-ai
    agents: 7
    orquestrador: "@growth-orqx"
    invoke: "/growth:agents:growth-orqx"
    description: "Analytics, CRO, SEO, growth hacking"
    keywords: ["growth", "cro", "seo", "analytics", "conversão", "funil", "retenção"]
    quando_usar:
      - "otimizar taxas de conversão"
      - "análise de funil"
      - "estratégia de SEO"

  # ── DADOS ─────────────────────────────────────────────────────
  - id: squad-research
    name: "Research Squad"
    source: sinapse-ai
    agents: 8
    orquestrador: "@research-orqx"
    invoke: "/research:agents:research-orqx"
    description: "Market analysis, inteligência competitiva, analytics"
    keywords: ["dados", "analytics", "métricas", "dashboard", "relatório", "KPI", "pesquisa", "mercado", "competidor"]
    quando_usar:
      - "criar ou revisar dashboards"
      - "análise de dados de clientes"
      - "definir métricas de sucesso"
      - "pesquisa de mercado para cliente"
      - "análise competitiva"

  # ── STORYTELLING ──────────────────────────────────────────────
  - id: squad-storytelling
    name: "Storytelling Squad"
    source: sinapse-ai
    agents: 9
    orquestrador: "@storytelling-orqx"
    invoke: "/narrative:agents:storytelling-orqx"
    description: "Narrativa, roteiros, frameworks de história"
    keywords: ["história", "narrativa", "storytelling", "roteiro", "pitch", "apresentação"]
    quando_usar:
      - "criar pitch deck"
      - "escrever narrativa de produto"
      - "estruturar apresentações"

  # ── COMMERCIAL / VENDAS ───────────────────────────────────────
  - id: squad-commercial
    name: "Commercial Squad"
    source: sinapse-ai
    agents: 11
    orquestrador: "@commercial-orqx"
    invoke: "/commercial:agents:commercial-orqx"
    description: "Pipeline comercial, ofertas, pricing, funil de vendas"
    keywords: ["oferta", "pricing", "venda", "proposta", "deal", "receita", "escala", "pipeline", "funil", "prospecção", "lead", "qualificação"]
    quando_usar:
      - "estruturar oferta para cliente"
      - "definir precificação"
      - "criar proposta comercial"
      - "estratégia de vendas"
      - "estruturar pipeline de vendas"
      - "qualificar leads"

  # ── ADVISORY BOARD ────────────────────────────────────────────
  - id: squad-council
    name: "Council / Advisory Board"
    source: sinapse-ai
    agents: 11
    orquestrador: "@council-orqx"
    invoke: "/council:agents:council-orqx"
    description: "Conselheiros estratégicos (Dalio, Munger, Naval, Thiel, Reid Hoffman)"
    keywords: ["estratégia", "decisão", "investimento", "risco", "visão", "longo prazo"]
    quando_usar:
      - "decisões estratégicas de alto impacto"
      - "validar direção do negócio"
      - "pensar em riscos de longo prazo"

  # ── PRODUTO ───────────────────────────────────────────────────
  - id: squad-product
    name: "Product Squad"
    source: sinapse-ai
    agents: 7
    orquestrador: "@product-orqx"
    invoke: "/product:agents:product-orqx"
    description: "Product discovery, roadmap, delivery, C-level virtual"
    keywords: ["executivo", "ceo", "cto", "cmo", "operação", "empresa", "visão", "produto", "roadmap", "discovery"]
    quando_usar:
      - "decisões operacionais da Zvision"
      - "estrutura da empresa"
      - "roadmap estratégico"
      - "product discovery"

  # ── ANIMATIONS ────────────────────────────────────────────────
  - id: squad-animations
    name: "Animations Squad"
    source: sinapse-ai
    agents: 9
    orquestrador: "@animations-orqx"
    invoke: "/ca:agents:animations-orqx"
    description: "Motion design, CSS animations, partículas, Three.js, shaders"
    keywords: ["animação", "motion", "3d", "partícula", "transição", "keyframe", "spline", "threejs", "shader"]
    quando_usar:
      - "criar animações para landing pages"
      - "efeitos visuais premium para clientes"
      - "motion design de interface"

  # ── CLONING ───────────────────────────────────────────────────
  - id: squad-cloning
    name: "Cloning Squad"
    source: sinapse-ai
    agents: 9
    orquestrador: "@cloning-orqx"
    invoke: "/SINAPSE:agents:cloning-orqx"
    description: "Digital twins, clonagem cognitiva, mind synthesis"
    keywords: ["clone", "persona", "digital twin", "voz", "estilo", "replicar"]
    quando_usar:
      - "criar agente com voz de cliente"
      - "replicar estilo de comunicação"
      - "digital twin de fundador"

  # ── FINANCE ───────────────────────────────────────────────────
  - id: squad-finance
    name: "Finance Squad"
    source: sinapse-ai
    agents: 5
    orquestrador: "@finance-orqx"
    invoke: "/finance:agents:finance-orqx"
    description: "Budget, pricing, profitability analysis"
    keywords: ["financeiro", "budget", "custo", "lucro", "caixa", "projeção", "roi"]
    quando_usar:
      - "análise financeira da Zvision"
      - "projeção de caixa"
      - "análise de ROI de projeto"

  # ── CONTENT ───────────────────────────────────────────────────
  - id: squad-content
    name: "Content Squad"
    source: sinapse-ai
    agents: 7
    orquestrador: "@content-orqx"
    invoke: "/content:agents:content-orqx"
    description: "Governança editorial, estratégia de conteúdo"
    keywords: ["conteúdo", "editorial", "blog", "artigo", "social", "instagram", "linkedin"]
    quando_usar:
      - "criar estratégia de conteúdo"
      - "produzir conteúdo para Zvision ou clientes"

  # ── COURSES ───────────────────────────────────────────────────
  - id: squad-courses
    name: "Courses Squad"
    source: sinapse-ai
    agents: 8
    orquestrador: "@courses-orqx"
    invoke: "/SINAPSE:agents:courses-orqx"
    description: "Cursos, currículos, assessments, launch educacional"
    keywords: ["curso", "treinamento", "educação", "aula", "módulo", "assessment"]
    quando_usar:
      - "criar treinamento para cliente"
      - "desenvolver curso da Zvision"
      - "estruturar onboarding educacional"

  # ── CLAUDE CODE MASTERY ───────────────────────────────────────
  - id: squad-claude
    name: "Claude Code Mastery"
    source: sinapse-ai
    agents: 10
    orquestrador: "@claude-orqx"
    invoke: "/claude:agents:claude-orqx"
    description: "Claude Code avançado, MCP, hooks, skills"
    keywords: ["claude code", "mcp", "hook", "skill", "agent", "workflow", "automatizar"]
    quando_usar:
      - "criar novos agentes ou skills"
      - "configurar MCPs"
      - "automatizar workflow do Claude Code"

# ── FERRAMENTAS GLOBAIS (não são squads, são skills) ───────────
tools:
  gstack:
    - /office-hours
    - /plan-ceo-review
    - /plan-eng-review
    - /review
    - /qa
    - /cso
    - /ship
    - /retro
    - /investigate
    - /design-review
    - /design-shotgun
    - /design-html
    - /learn
    - /browse

  highermind:
    - /hm-init
    - /hm-engineer
    - /hm-designer
    - /hm-qa

  psters:
    - /pwf-brainstorm
    - /pwf-plan
    - /pwf-work-plan
    - /pwf-work
    - /pwf-review
    - /pwf-doc
    - /pwf-commit-changes

  opensquad:
    - /opensquad
    - /opensquad create
    - /opensquad run

# ── PROTOCOLO OBRIGATÓRIO ──────────────────────────────────────
protocol:
  toda_feature:
    1: "/pwf-brainstorm — shape a ideia e constraints"
    2: "/pwf-plan — converte em fases"
    3: "/pwf-work-plan — executa uma fase por vez"
    4: "/pwf-review — review estruturado"
    5: "/pwf-commit-changes — commit bem estruturado"

  antes_de_qualquer_trabalho:
    - "ler obsidian-vault/index.md"
    - "navegar o MOC do domínio relevante"
    - "verificar se já foi decidido antes"

  depois_de_qualquer_trabalho:
    - "documentar no vault"
    - "atualizar o node relevante com wikilinks"
